# Postgres connection string (required). Local Postgres example:
# DATABASE_URL="postgresql://username:password@localhost:5432/construction_multitool"
# After setting this, run `npm run db:migrate` once to create the schema.
DATABASE_URL="postgresql://username:password@localhost:5432/construction_multitool"

# You only need ONE of these keys — whichever provider the user selects in the
# app's provider picker at analysis time. Setting both is fine too (lets users
# switch freely between them in the UI).

# Google Gemini — recommended for students / no-budget use. Free tier, no
# credit card required. Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key-here

# Anthropic Claude — pay-as-you-go, no free tier. Get a key at
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Kimi (Moonshot AI) — pay-as-you-go, no free tier. Native image
# understanding, very large context window. Get a key at
# https://platform.moonshot.ai/console/api-keys
KIMI_API_KEY=your-kimi-key-here

# --- Optional overrides -------------------------------------------------
# Change these only if Google/Anthropic/Moonshot ship a newer model you want to pin to.
# GEMINI_VISION_MODEL=gemini-3.5-flash
# CLAUDE_VISION_MODEL=claude-3-5-sonnet-20241022
# KIMI_VISION_MODEL=kimi-k3
