# You only need ONE of these keys — whichever provider the user selects in the
# app's provider picker at analysis time. Setting both is fine too (lets users
# switch freely between them in the UI).

# Google Gemini — recommended for students / no-budget use. Free tier, no
# credit card required. Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key-here

# Anthropic Claude — pay-as-you-go, no free tier. Get a key at
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Optional overrides -------------------------------------------------
# Change these only if Google/Anthropic ship a newer model you want to pin to.
# GEMINI_VISION_MODEL=gemini-2.5-flash-lite
# CLAUDE_VISION_MODEL=claude-3-5-sonnet-20241022
